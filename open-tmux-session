#!/usr/bin/env bash

# Colour Palette: https://i.sstatic.net/e63et.png

SESSION_NAMES=()
SESSION_DESCS=()
SESSION_FUNCS=()

register_session() {
  local name=$1 desc=$2 func=$3
  SESSION_NAMES+=("$name")
  SESSION_DESCS+=("$desc")
  SESSION_FUNCS+=("$func")
}

set_style() {
  local session=$1 bg=$2 fg=${3:-}
  tmux set -t "$session" status-bg "$bg"
  [ -n "$fg" ] && tmux set -t "$session" status-fg "$fg"
}

attach_or_switch() {
  local session=$1
  if [ -n "$TMUX" ]; then
    tmux switch-client -t "$session"
  else
    tmux attach -t "$session"
  fi
}

# Built-in session setup functions
_setup_notes() {
  tmux new-session -d -s "$SESSION" -n 'notes' -c ~/src/jasperRob/notes/
  set_style "$SESSION" colour5 colour0
}

_setup_config() {
  tmux new-session -d -s "$SESSION" -n 'config' -c ~/
  set_style "$SESSION" colour209 colour0
}

_setup_misc() {
  tmux new-session -d -s "$SESSION" -n 'misc' -c ~/misc/
  set_style "$SESSION" colour2 colour0
}

# Register built-in sessions
register_session "notes"  "Notes"         "_setup_notes"
register_session "config" "Config"        "_setup_config"
register_session "misc"   "Miscellaneous" "_setup_misc"

# Load local addon session configs
ADDON_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/open-tmux-sessions"
if [ -d "$ADDON_DIR" ]; then
  for f in "$ADDON_DIR"/*.sh; do
    [ -f "$f" ] && source "$f"
  done
fi

# Build menu and resolve session name
if [ -n "$1" ]; then
  choice="$1"
else
  echo "Select a session to open:"
  for i in "${!SESSION_NAMES[@]}"; do
    printf "  %d) %s\n" "$((i+1))" "${SESSION_DESCS[$i]}"
  done
  read -rp "Enter choice [1-${#SESSION_NAMES[@]}]: " choice
fi

# Match by number or name
SESSION=""
FUNC=""
for i in "${!SESSION_NAMES[@]}"; do
  if [[ "$choice" == "$((i+1))" || "$choice" == "${SESSION_NAMES[$i]}" ]]; then
    SESSION="${SESSION_NAMES[$i]}"
    FUNC="${SESSION_FUNCS[$i]}"
    break
  fi
done

if [ -z "$SESSION" ]; then
  echo "Invalid choice: $choice"
  exit 1
fi

# Attach if session already exists
if tmux has-session -t "$SESSION" 2>/dev/null; then
  echo "Switching to existing session: $SESSION"
  attach_or_switch "$SESSION"
  exit 0
fi

# Run setup function
"$FUNC"

# Attach or switch to the session
attach_or_switch "$SESSION"
